# Copia questo file in ".env" e inserisci i tuoi valori reali.
# Il file ".env" non viene mai versionato su git (vedi .gitignore).

# --- Telecamera ONVIF ---
CAMERA_IP=192.168.1.100
CAMERA_PORT=80
CAMERA_USER=admin
CAMERA_PASSWORD=changeme

# Cartella con i file WSDL di onvif-zeep. Lascia vuoto per usare la copia
# vendorizzata in vendor/wsdl (necessaria: il pacchetto onvif-zeep su PyPI
# non installa correttamente i propri file WSDL di default).
CAMERA_WSDL_DIR=

# Metodo di cattura: "onvif" usa GetSnapshotUri (consigliato, più leggero).
# "rtsp" forza la cattura di un frame dallo stream RTSP via OpenCV,
# utile se la camera non supporta bene lo snapshot ONVIF.
CAPTURE_METHOD=onvif

# --- Schedulazione ---
# Ogni quanti secondi lo scheduler scatta un nuovo screenshot dalla camera.
SNAPSHOT_INTERVAL_SECONDS=60

# --- Percorsi ---
# Dove scheduler.py e index.mu leggono/scrivono la cache dell'ultimo ascii art.
CACHE_DIR=cache

# --- Storico screenshot (opzionale) ---
# Se true, ogni cattura viene salvata anche come JPEG in cache/history/
# (nome file a timestamp), oltre a aggiornare il solo "ultimo scatto".
SAVE_HISTORY=false

# Cancella automaticamente dallo storico i file piu' vecchi di N ore.
# 0 disattiva questo criterio (nessun limite di eta').
HISTORY_RETENTION_HOURS=168

# Tetto di sicurezza indipendente dall'eta': se dopo la pulizia per eta'
# restano piu' di N file, cancella i piu' vecchi finche' non rientra nel
# limite. 0 disattiva questo criterio (nessun limite sul numero di file).
HISTORY_MAX_FILES=500
