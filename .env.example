# Copia questo file in ".env" e inserisci i tuoi valori reali.
# Il file ".env" non viene mai versionato su git (vedi .gitignore).

# --- Telecamera ---
CAMERA_IP=192.168.1.100
CAMERA_PORT=80
CAMERA_USER=admin
CAMERA_PASSWORD=changeme

# Protocollo della telecamera: "onvif" (standard, generico), "dahua"
# (CGI HTTP + RTSP proprietari Dahua, compatibili anche con molti OEM come
# Amcrest), "reolink" (API HTTP + RTSP proprietari Reolink) oppure "rtsp"
# (nessuna scoperta: si usa direttamente CAMERA_RTSP_URL qui sotto).
CAMERA_PROTOCOL=onvif

# Cartella con i file WSDL di onvif-zeep (usata solo con CAMERA_PROTOCOL=onvif).
# Lascia vuoto per usare la copia vendorizzata in vendor/wsdl (necessaria: il
# pacchetto onvif-zeep su PyPI non installa correttamente i propri file WSDL
# di default).
CAMERA_WSDL_DIR=

# Metodo di cattura per i protocolli con scoperta HTTP (onvif/dahua/reolink):
# "snapshot" usa l'endpoint HTTP di snapshot (consigliato, più leggero).
# "rtsp" forza la cattura di un frame dallo stream RTSP via OpenCV, utile se
# la camera non supporta bene lo snapshot HTTP. Se lo snapshot fallisce, il
# fallback RTSP scatta comunque in automatico anche con CAPTURE_METHOD=snapshot.
CAPTURE_METHOD=snapshot

# Canale/telecamera su NVR multi-canale (Dahua e Reolink), 1-based.
# Per una singola telecamera lascia 1.
CAMERA_CHANNEL=1

# Substream RTSP per Dahua/Reolink: "main" (alta risoluzione, consigliato)
# oppure "sub" (bassa risoluzione, più leggero su reti lente come LoRa).
CAMERA_STREAM_SUBTYPE=main

# URL RTSP completo, usato solo con CAMERA_PROTOCOL=rtsp (telecamere generiche
# senza ONVIF/CGI proprietario). Utente/password sopra vengono iniettati
# automaticamente se non già presenti nell'URL.
# Esempio: rtsp://192.168.1.100:554/stream1
CAMERA_RTSP_URL=

# --- Schedulazione ---
# Ogni quanti secondi lo scheduler scatta un nuovo screenshot dalla camera.
SNAPSHOT_INTERVAL_SECONDS=60

# --- Percorsi ---
# Dove scheduler.py e index.mu leggono/scrivono la cache dell'ultimo ascii art.
CACHE_DIR=cache

# --- Storico screenshot (opzionale) ---
# Se true, ogni cattura viene salvata anche come JPEG in cache/history/
# (nome file a timestamp), oltre a aggiornare il solo "ultimo scatto".
SAVE_HISTORY=false

# Cancella automaticamente dallo storico i file piu' vecchi di N ore.
# 0 disattiva questo criterio (nessun limite di eta').
HISTORY_RETENTION_HOURS=168

# Tetto di sicurezza indipendente dall'eta': se dopo la pulizia per eta'
# restano piu' di N file, cancella i piu' vecchi finche' non rientra nel
# limite. 0 disattiva questo criterio (nessun limite sul numero di file).
HISTORY_MAX_FILES=500
