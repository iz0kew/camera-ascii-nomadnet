# Segreti e configurazione locale
.env

# Cache generata a runtime (screenshot/ascii/metadati, incluso lo storico
# in cache/history/: "**" serve a coprire anche quella sottocartella)
cache/*.txt
cache/*.json
cache/*.tmp
cache/**/*.jpg
!cache/.gitkeep

# Python
__pycache__/
*.pyc
venv/
.venv/
*.egg-info/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Impostazioni locali di Claude Code (specifiche della macchina)
.claude/
